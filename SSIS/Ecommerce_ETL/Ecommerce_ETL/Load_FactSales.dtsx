                    <inputColumn
                      refId="Package\Load_FactSales\Derived Column Salary.Inputs[Derived Column Input].Columns[Discount]"
                      cachedDataType="numeric"
                      cachedName="Discount"
                      cachedPrecision="5"
                      cachedScale="2"
