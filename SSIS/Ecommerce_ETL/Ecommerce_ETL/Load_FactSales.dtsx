                  name="Derived Column Output"
                  synchronousInputId="Package\Load_FactSales\Derived Column Salary.Inputs[Derived Column Input]">
                  <outputColumns>
                    <outputColumn
                      refId="Package\Load_FactSales\Derived Column Salary.Outputs[Derived Column Output].Columns[GrossSales]"
                      dataType="numeric"
                      errorOrTruncationOperation="Computation"
                      errorRowDisposition="FailComponent"
                      lineageId="Package\Load_FactSales\Derived Column Salary.Outputs[Derived Column Output].Columns[GrossSales]"
                      name="GrossSales"
                      precision="21"
                      scale="2"
                      truncationRowDisposition="FailComponent">
                      <properties>
                        <property
                          containsID="true"
                          dataType="System.String"
                          description="Derived Column Expression"
                          name="Expression">#{Package\Load_FactSales\OLE DB Source FactSales.Outputs[OLE DB Source Output].Columns[Quantity]} * #{Package\Load_FactSales\OLE DB Source FactSales.Outputs[OLE DB Source Output].Columns[UnitPrice]}</property>
                        <property
                          containsID="true"
                          dataType="System.String"
                          description="Derived Column Friendly Expression"
                          expressionType="Notify"
                          name="FriendlyExpression">Quantity * UnitPrice</property>
                      </properties>
                    </outputColumn>
                    <outputColumn
                      refId="Package\Load_FactSales\Derived Column Salary.Outputs[Derived Column Output].Columns[DiscountAmount]"
                      dataType="numeric"
                      errorOrTruncationOperation="Computation"
                      errorRowDisposition="FailComponent"
                      lineageId="Package\Load_FactSales\Derived Column Salary.Outputs[Derived Column Output].Columns[DiscountAmount]"
                      name="DiscountAmount"
                      precision="38"
                      scale="15"
                      truncationRowDisposition="FailComponent">
                      <properties>
                        <property
                          containsID="true"
                          dataType="System.String"
                          description="Derived Column Expression"
                          name="Expression">(#{Package\Load_FactSales\OLE DB Source FactSales.Outputs[OLE DB Source Output].Columns[Quantity]} * #{Package\Load_FactSales\OLE DB Source FactSales.Outputs[OLE DB Source Output].Columns[UnitPrice]}) * (#{Package\Load_FactSales\OLE DB Source FactSales.Outputs[OLE DB Source Output].Columns[Discount]} / 100)</property>
                        <property
                          containsID="true"
                          dataType="System.String"
                          description="Derived Column Friendly Expression"
                          expressionType="Notify"
                          name="FriendlyExpression">(Quantity * UnitPrice) * (Discount / 100)</property>
                      </properties>
                    </outputColumn>
                    <outputColumn
                      refId="Package\Load_FactSales\Derived Column Salary.Outputs[Derived Column Output].Columns[NetSales]"
                      dataType="numeric"
                      errorOrTruncationOperation="Computation"
                      errorRowDisposition="FailComponent"
                      lineageId="Package\Load_FactSales\Derived Column Salary.Outputs[Derived Column Output].Columns[NetSales]"
                      name="NetSales"
                      precision="38"
                      scale="15"
                      truncationRowDisposition="FailComponent">
                      <properties>
                        <property
                          containsID="true"
                          dataType="System.String"
                          description="Derived Column Expression"
                          name="Expression">(#{Package\Load_FactSales\OLE DB Source FactSales.Outputs[OLE DB Source Output].Columns[Quantity]} * #{Package\Load_FactSales\OLE DB Source FactSales.Outputs[OLE DB Source Output].Columns[UnitPrice]}) - ((#{Package\Load_FactSales\OLE DB Source FactSales.Outputs[OLE DB Source Output].Columns[Quantity]} * #{Package\Load_FactSales\OLE DB Source FactSales.Outputs[OLE DB Source Output].Columns[UnitPrice]}) * (#{Package\Load_FactSales\OLE DB Source FactSales.Outputs[OLE DB Source Output].Columns[Discount]} / 100))</property>
                        <property
                          containsID="true"
                          dataType="System.String"
                          description="Derived Column Friendly Expression"
                          expressionType="Notify"
                          name="FriendlyExpression">(Quantity * UnitPrice) - ((Quantity * UnitPrice) * (Discount / 100))</property>
                      </properties>
                    </outputColumn>
                  </outputColumns>
                  <externalMetadataColumns />
                </output>
