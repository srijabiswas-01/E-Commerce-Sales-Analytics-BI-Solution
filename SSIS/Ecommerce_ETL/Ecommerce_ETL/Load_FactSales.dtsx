                      lineageId="Package\Load_FactSales\OLE DB Source FactSales.Outputs[OLE DB Source Output].Columns[Quantity]" />
                    <inputColumn
                      refId="Package\Load_FactSales\Derived Column Salary.Inputs[Derived Column Input].Columns[UnitPrice]"
                      cachedDataType="numeric"
                      cachedName="UnitPrice"
                      cachedPrecision="10"
                      cachedScale="2"
