  <DataSources>
    <DataSource Name="EcommerceDW_DS">
      <DataSourceReference>EcommerceDW_DS</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>fa50f9b1-8e49-4b3c-bef5-29759d983347</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="KPI_Cards">
      <Query>
        <DataSourceName>EcommerceDW_DS</DataSourceName>
        <CommandText>SELECT
    SUM(NetSales) AS TotalRevenue,
    COUNT(OrderID) AS TotalOrders,
    COUNT(DISTINCT CustomerKey) AS TotalCustomers,
    AVG(NetSales) AS AvgOrderValue
FROM FactSales</CommandText>
      </Query>
      <Fields>
        <Field Name="TotalRevenue">
          <DataField>TotalRevenue</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="TotalOrders">
          <DataField>TotalOrders</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TotalCustomers">
          <DataField>TotalCustomers</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="AvgOrderValue">
          <DataField>AvgOrderValue</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Monthly_Revenue_Trend">
      <Query>
        <DataSourceName>EcommerceDW_DS</DataSourceName>
        <CommandText>SELECT
    d.Year,
    d.Month,
    d.MonthName,
    SUM(f.NetSales) AS Revenue
FROM FactSales f
JOIN DimDate d ON f.DateKey = d.DateKey
GROUP BY
    d.Year,
    d.Month,
    d.MonthName
ORDER BY
    d.Year,
    d.Month</CommandText>
      </Query>
      <Fields>
        <Field Name="Year">
          <DataField>Year</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Month">
          <DataField>Month</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="MonthName">
          <DataField>MonthName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Revenue">
          <DataField>Revenue</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Product_Category_Analysis">
      <Query>
        <DataSourceName>EcommerceDW_DS</DataSourceName>
        <CommandText>SELECT
    p.Category,
    SUM(f.NetSales) Revenue
FROM FactSales f
JOIN DimProduct p
ON f.ProductKey=p.ProductKey
GROUP BY
    p.Category</CommandText>
      </Query>
      <Fields>
        <Field Name="Category">
          <DataField>Category</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Revenue">
          <DataField>Revenue</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Payment_Distribution">
      <Query>
        <DataSourceName>EcommerceDW_DS</DataSourceName>
        <CommandText>SELECT
    p.PaymentMethod,
    COUNT(*) Orders
FROM FactSales f
JOIN DimPayment p
ON f.PaymentKey=p.PaymentKey
GROUP BY
    p.PaymentMethod</CommandText>
      </Query>
      <Fields>
        <Field Name="PaymentMethod">
          <DataField>PaymentMethod</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Orders">
          <DataField>Orders</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Top_10_Customers">
      <Query>
        <DataSourceName>EcommerceDW_DS</DataSourceName>
        <CommandText>SELECT TOP 10
    c.CustomerName,
    SUM(f.NetSales) Revenue
FROM FactSales f
JOIN DimCustomer c
ON f.CustomerKey=c.CustomerKey
GROUP BY
    c.CustomerName
ORDER BY Revenue DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="CustomerName">
          <DataField>CustomerName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Revenue">
          <DataField>Revenue</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Detailed_Sales_Table">
      <Query>
        <DataSourceName>EcommerceDW_DS</DataSourceName>
        <CommandText>SELECT TOP 100
    d.FullDate,
    c.CustomerName,
    p.ProductName,
    pay.PaymentMethod,
    f.Quantity,
    f.NetSales
FROM FactSales f
JOIN DimDate d
ON f.DateKey=d.DateKey
JOIN DimCustomer c
ON f.CustomerKey=c.CustomerKey
JOIN DimProduct p
ON f.ProductKey=p.ProductKey
JOIN DimPayment pay
ON f.PaymentKey=pay.PaymentKey
ORDER BY d.FullDate DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="FullDate">
          <DataField>FullDate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="CustomerName">
          <DataField>CustomerName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ProductName">
          <DataField>ProductName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PaymentMethod">
          <DataField>PaymentMethod</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Quantity">
          <DataField>Quantity</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="NetSales">
          <DataField>NetSales</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
